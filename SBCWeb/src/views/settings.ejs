<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nastavení - IoT Control</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            'ash-grey': {'50':'#f2f3f1','100':'#e6e7e4','200':'#ccd0c8','300':'#b3b8ad','400':'#9aa092','500':'#808877','600':'#676d5f','700':'#4d5247','800':'#33372f','900':'#1a1b18','950':'#121311'},
            'silver': {'50':'#f2f3f2','100':'#e5e6e5','200':'#cbcdcb','300':'#b1b4b1','400':'#979b97','500':'#7d827d','600':'#646864','700':'#4b4e4b','800':'#323432','900':'#191a19','950':'#111211'},
            'vintage-grape': {'50':'#f3f0f4','100':'#e7e2e9','200':'#cfc4d4','300':'#b7a7be','400':'#a08aa8','500':'#886c93','600':'#6d5775','700':'#514158','800':'#362b3b','900':'#1b161d','950':'#130f15'},
            'midnight-violet': {'50':'#f3eff5','100':'#e8e0eb','200':'#d0c1d7','300':'#b9a2c3','400':'#a183af','500':'#8a639c','600':'#6e507c','700':'#533c5d','800':'#37283e','900':'#1c141f','950':'#130e16'}
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script>
        // Zabránění FOUC
        if (localStorage.getItem('ui_theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>

<body class="bg-ash-grey-50 dark:bg-midnight-violet-950 dark:text-silver-100 min-h-screen transition-colors duration-300">

<div id="toast-success" class="hidden fixed bottom-8 right-8 z-[10000] flex items-stretch min-w-[300px] bg-white dark:bg-midnight-violet-900 text-gray-900 dark:text-silver-100 rounded-lg shadow-xl border border-gray-100 dark:border-midnight-violet-800 overflow-hidden transition-all duration-700 opacity-0 translate-y-4">
    <div class="w-3 bg-green-500 shrink-0"></div>
    <div class="flex items-center py-4 px-5 w-full">
        <div class="flex items-center justify-center flex-shrink-0 h-8 w-8 bg-green-100 dark:bg-green-900/30 rounded-full mr-3">
            <i class="fas fa-check text-green-600 dark:text-green-400"></i>
        </div>
        <div id="toast-message-success" class="flex-1 text-sm font-semibold text-gray-800 dark:text-silver-100"></div>
    </div>
</div>

<div id="toast-error" class="hidden fixed bottom-8 right-8 z-[10000] flex items-stretch min-w-[300px] bg-white dark:bg-midnight-violet-900 text-gray-900 dark:text-silver-100 rounded-lg shadow-xl border border-gray-100 dark:border-midnight-violet-800 overflow-hidden transition-all duration-700 opacity-0 translate-y-4">
    <div class="w-3 bg-red-500 shrink-0"></div>
    <div class="flex items-center py-4 px-5 w-full">
        <div class="flex items-center justify-center flex-shrink-0 h-8 w-8 bg-red-100 dark:bg-red-900/30 rounded-full mr-3">
            <i class="fas fa-times text-red-600 dark:text-red-400"></i>
        </div>
        <div id="toast-message-error" class="flex-1 text-sm font-semibold text-gray-800 dark:text-silver-100"></div>
    </div>
</div>

<aside id="sidebar" class="fixed top-0 left-0 h-full w-64 bg-midnight-violet-900 dark:bg-[#0c090f] shadow-2xl transition-all duration-300 ease-in-out z-40">
  <div class="flex flex-col h-full">
    <div class="p-6 border-b border-midnight-violet-800 dark:border-midnight-violet-900">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3 overflow-hidden">
          <div class="w-10 h-10 bg-gradient-to-br from-vintage-grape-400 to-midnight-violet-500 rounded-lg shadow-lg flex-shrink-0"></div>
          <span class="text-ash-grey-50 font-bold text-lg whitespace-nowrap">IoT Control</span>
        </div>
        <button id="closeSidebar" class="text-ash-grey-300 hover:text-ash-grey-50 lg:hidden">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>

    <nav class="flex-1 overflow-y-auto p-4">
      <div class="space-y-6">
        <div>
          <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider mb-3">Menu</h3>
          <div class="space-y-1">
            <a href="/dashboard" class="w-full flex items-center space-x-3 px-4 py-2.5 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 dark:hover:bg-midnight-violet-900 transition">
              <i class="fas fa-home w-5 text-center flex-shrink-0"></i>
              <span class="whitespace-nowrap font-medium">Dashboard</span>
            </a>
            <a href="/mcu" class="w-full flex items-center space-x-3 px-4 py-2.5 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 dark:hover:bg-midnight-violet-900 transition">
              <i class="fas fa-microchip w-5 text-center flex-shrink-0"></i>
              <span class="whitespace-nowrap font-medium">MCU Controllers</span>
            </a>
            <a href="/server" class="w-full flex items-center space-x-3 px-4 py-2.5 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 dark:hover:bg-midnight-violet-900 transition">
              <i class="fas fa-server w-5 text-center flex-shrink-0"></i>
              <span class="whitespace-nowrap font-medium">Servers</span>
            </a>
            <a href="/settings" class="w-full flex items-center space-x-3 px-4 py-2.5 rounded-lg bg-midnight-violet-800 dark:bg-midnight-violet-900/50 text-white transition shadow-inner">
              <i class="fas fa-cog w-5 text-center text-vintage-grape-400 flex-shrink-0"></i>
              <span class="whitespace-nowrap font-bold">Nastavení</span>
            </a>
          </div>
        </div>
      </div>
    </nav>
  </div>
</aside>

<div id="mainContent" class="lg:ml-64 transition-all duration-300">
  
  <header class="bg-white dark:bg-midnight-violet-900 shadow-sm border-b border-ash-grey-200 dark:border-midnight-violet-800 sticky top-0 z-30 transition-colors duration-300">
  <div class="px-6 py-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <h1 class="text-2xl font-bold text-midnight-violet-900 dark:text-silver-50">Nastavení systému</h1>
      </div>

      <div class="flex items-center space-x-4">
        <a href="/dashboard" class="header-btn p-2 text-silver-500 dark:text-silver-400 hover:text-midnight-violet-700 dark:hover:text-silver-200 transition" title="Dashboard">
          <i class="fas fa-home text-xl"></i>
        </a>

        <div class="relative" id="notificationContainer">
          <button id="notificationBellBtn" class="header-btn relative p-2 text-silver-500 dark:text-silver-400 hover:text-midnight-violet-700 dark:hover:text-silver-200 transition" title="Notifications">
            <i class="fas fa-bell text-xl"></i>
            <span id="notificationBadge" class="hidden absolute top-0 right-0 w-4 h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center border-2 border-white shadow-sm">0</span>
          </button>

          <div id="notificationDropdown" class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-midnight-violet-900 rounded-xl shadow-2xl border border-ash-grey-200 dark:border-midnight-violet-800 z-[100] overflow-hidden">
            <div class="px-4 py-3 border-b border-ash-grey-100 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex justify-between items-center">
              <h3 class="font-bold text-midnight-violet-900 dark:text-silver-100 text-sm flex items-center gap-2">
                <i class="fas fa-history text-vintage-grape-500"></i> Historie událostí
              </h3>
              <button id="clearNotificationsBtn" class="text-xs font-semibold text-silver-400 hover:text-red-500 transition-colors">
                Vymazat
              </button>
            </div>

            <div id="notificationList" class="max-h-72 overflow-y-auto p-2 bg-white dark:bg-midnight-violet-900">
              <div class="text-center text-sm text-silver-400 py-6" id="emptyNotifications">
                <i class="fas fa-bell-slash text-2xl mb-2 opacity-50 block"></i>
                Zatím vše běží jak má.
              </div>
              </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</header>

  <main class="p-6 max-w-5xl mx-auto">
      
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
      <p class="text-sm text-silver-500 dark:text-silver-400 font-medium">Správa konfigurace pro backend služby a uživatelské rozhraní.</p>
      <button id="saveSettingsBtn" class="px-6 py-2.5 bg-vintage-grape-600 hover:bg-vintage-grape-700 text-white font-semibold rounded-lg shadow-sm transition-colors flex items-center gap-2">
        <i class="fas fa-save"></i> Uložit nastavení
      </button>
    </div>

    <div class="space-y-6">

      <div class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden transition-colors duration-300">
        <div class="px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-midnight-violet-100 dark:bg-midnight-violet-800 text-midnight-violet-900 dark:text-vintage-grape-300 flex items-center justify-center">
            <i class="fas fa-network-wired"></i>
          </div>
          <h2 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-100">Síť a Komunikace</h2>
        </div>
        
        <div class="p-6 space-y-6 bg-white dark:bg-[#150f18] transition-colors duration-300">
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">IP adresa MQTT Brokeru</label>
            <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Adresa pro komunikaci se senzory a MCU.</p>
            <div class="relative">
              <i class="fas fa-wifi absolute left-4 top-1/2 transform -translate-y-1/2 text-silver-400 dark:text-silver-500"></i>
              <input type="text" id="setting_mqtt_broker_ip" placeholder="např. 192.168.1.150" class="w-full pl-11 pr-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm font-mono text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Interval kontroly MCU (ms)</label>
              <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Doba mezi pingováním čipů.</p>
              <input type="number" id="setting_mcu_ping_interval" placeholder="30000" class="w-full px-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm font-mono text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all">
            </div>
            
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Interval kontroly Serverů (ms)</label>
              <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Doba mezi odesláním ICMP pingu.</p>
              <input type="number" id="setting_server_ping_interval" placeholder="60000" class="w-full px-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm font-mono text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all">
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden transition-colors duration-300">
        <div class="px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-vintage-grape-100 dark:bg-vintage-grape-900/50 text-vintage-grape-700 dark:text-vintage-grape-300 flex items-center justify-center">
            <i class="fas fa-desktop"></i>
          </div>
          <h2 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-100">Vzhled a Prostředí</h2>
        </div>
        
        <div class="p-6 space-y-8 bg-white dark:bg-[#150f18] transition-colors duration-300">
          <div class="space-y-3">
            <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Vzhled rozhraní</label>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              
              <label class="cursor-pointer relative">
                <input type="radio" name="ui_theme" value="light" class="peer sr-only" checked>
                <div class="p-4 bg-ash-grey-50 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg hover:border-vintage-grape-400 dark:hover:border-vintage-grape-500 peer-checked:border-vintage-grape-500 dark:peer-checked:border-vintage-grape-400 peer-checked:ring-1 peer-checked:ring-vintage-grape-500 transition-all text-center">
                  <i class="fas fa-sun text-2xl text-amber-500 mb-2"></i>
                  <span class="block text-sm font-bold text-midnight-violet-900 dark:text-silver-200">Světlý</span>
                </div>
              </label>
              
              <label class="cursor-pointer relative">
                <input type="radio" name="ui_theme" value="dark" class="peer sr-only">
                <div class="p-4 bg-ash-grey-50 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg hover:border-vintage-grape-400 dark:hover:border-vintage-grape-500 peer-checked:border-vintage-grape-500 dark:peer-checked:border-vintage-grape-400 peer-checked:ring-1 peer-checked:ring-vintage-grape-500 transition-all text-center">
                  <i class="fas fa-moon text-2xl text-midnight-violet-800 dark:text-silver-300 mb-2"></i>
                  <span class="block text-sm font-bold text-midnight-violet-900 dark:text-silver-200">Tmavý</span>
                </div>
              </label>
            </div>
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Časová zóna (Prohlížeč)</label>
            <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Vyberte, jak chcete formátovat časy pro tento prohlížeč.</p>
            <select id="ui_timezone" class="w-full px-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm text-gray-900 dark:text-silver-100 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%20viewBox%3D%220%200%2024%2024%20fill%3D%22none%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:1.25rem] bg-[right_1rem_center] bg-no-repeat">
              <option value="UTC">Nultý poledník (UTC)</option>
            </select>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<div id="sidebarOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden lg:hidden"></div>
<script src="/socket.io/socket.io.js"></script>
<script type="module" src="/js/pages/settings/main.js"></script>
<script src="/js/common/utils.js"></script>
<script src="/js/components/header.js"></script> 

</body>
</html>