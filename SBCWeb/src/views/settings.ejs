<%- include('partials/settings/head') %>
<%- include('partials/common/toastNotification') %>
<%- include('partials/settings/sidebar') %>

<style>
  /* Offset pro sticky header */
  #network-section,
  #appearance-section,
  #account-section {
    scroll-margin-top: 5rem;
  }
</style>

<div id="mainContent" class="lg:ml-64 transition-all duration-300">
  <%- include('partials/settings/header') %>

  <main class="p-6 max-w-5xl mx-auto">
      
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
      <p class="text-sm text-silver-500 dark:text-silver-400 font-medium">Správa konfigurace pro backend služby a uživatelské rozhraní.</p>
      <button id="saveSettingsBtn" class="px-6 py-2.5 bg-vintage-grape-600 hover:bg-vintage-grape-700 text-white font-semibold rounded-lg shadow-sm transition-colors flex items-center gap-2">
        <i class="fas fa-save"></i> Uložit nastavení
      </button>
    </div>

    <div class="space-y-6">

      <div id="network-section" class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden transition-colors duration-300">
        <div class="px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-midnight-violet-100 dark:bg-midnight-violet-800 text-midnight-violet-900 dark:text-vintage-grape-300 flex items-center justify-center">
            <i class="fas fa-network-wired"></i>
          </div>
          <h2 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-100">Síť a Komunikace</h2>
        </div>
        
        <div class="p-6 space-y-6 bg-white dark:bg-[#150f18] transition-colors duration-300">
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">IP adresa MQTT Brokeru</label>
            <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Adresa pro komunikaci se senzory a MCU.</p>
            <div class="relative">
              <i class="fas fa-wifi absolute left-4 top-1/2 transform -translate-y-1/2 text-silver-400 dark:text-silver-500"></i>
              <input type="text" id="setting_mqtt_broker_ip" placeholder="např. 192.168.1.150" class="w-full pl-11 pr-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm font-mono text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Interval kontroly MCU (ms)</label>
              <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Doba mezi pingováním čipů.</p>
              <input type="number" id="setting_mcu_ping_interval" placeholder="30000" class="w-full px-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm font-mono text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all">
            </div>
            
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Interval kontroly Serverů (ms)</label>
              <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Doba mezi odesláním ICMP pingu.</p>
              <input type="number" id="setting_server_ping_interval" placeholder="60000" class="w-full px-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm font-mono text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all">
            </div>
          </div>
        </div>
      </div>

      <div id="appearance-section" class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden transition-colors duration-300">
        <div class="px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-vintage-grape-100 dark:bg-vintage-grape-900/50 text-vintage-grape-700 dark:text-vintage-grape-300 flex items-center justify-center">
            <i class="fas fa-desktop"></i>
          </div>
          <h2 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-100">Vzhled a Prostředí</h2>
        </div>
        
        <div class="p-6 space-y-8 bg-white dark:bg-[#150f18] transition-colors duration-300">
          <div class="space-y-3">
            <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Vzhled rozhraní</label>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              
              <label class="cursor-pointer relative">
                <input type="radio" name="ui_theme" value="light" class="peer sr-only" checked>
                <div class="p-4 bg-ash-grey-50 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg hover:border-vintage-grape-400 dark:hover:border-vintage-grape-500 peer-checked:border-vintage-grape-500 dark:peer-checked:border-vintage-grape-400 peer-checked:ring-1 peer-checked:ring-vintage-grape-500 transition-all text-center">
                  <i class="fas fa-sun text-2xl text-amber-500 mb-2"></i>
                  <span class="block text-sm font-bold text-midnight-violet-900 dark:text-silver-200">Světlý</span>
                </div>
              </label>
              
              <label class="cursor-pointer relative">
                <input type="radio" name="ui_theme" value="dark" class="peer sr-only">
                <div class="p-4 bg-ash-grey-50 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg hover:border-vintage-grape-400 dark:hover:border-vintage-grape-500 peer-checked:border-vintage-grape-500 dark:peer-checked:border-vintage-grape-400 peer-checked:ring-1 peer-checked:ring-vintage-grape-500 transition-all text-center">
                  <i class="fas fa-moon text-2xl text-midnight-violet-800 dark:text-silver-300 mb-2"></i>
                  <span class="block text-sm font-bold text-midnight-violet-900 dark:text-silver-200">Tmavý</span>
                </div>
              </label>
            </div>
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Časová zóna (Prohlížeč)</label>
            <p class="text-xs text-silver-500 dark:text-silver-400 mb-1">Vyberte, jak chcete formátovat časy pro tento prohlížeč.</p>
            <select id="ui_timezone" class="w-full px-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm text-gray-900 dark:text-silver-100 focus:outline-none focus:border-vintage-grape-500 dark:focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-500 dark:focus:ring-vintage-grape-400 transition-all appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%20viewBox%3D%220%200%2024%2024%20fill%3D%22none%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:1.25rem] bg-[right_1rem_center] bg-no-repeat">
              <option value="UTC">Nultý poledník (UTC)</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Správa účtu -->
      <div id="account-section" class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden transition-colors duration-300">
        <div class="px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-vintage-grape-100 dark:bg-vintage-grape-900/50 text-vintage-grape-700 dark:text-vintage-grape-300 flex items-center justify-center">
            <i class="fas fa-user-shield"></i>
          </div>
          <h2 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-100">Správa účtu</h2>
        </div>

        <div class="p-6 space-y-8 bg-white dark:bg-[#150f18] transition-colors duration-300">

          <!-- Změna uživatelského jména -->
          <div class="space-y-3">
            <div>
              <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200 mb-0.5">Uživatelské jméno</label>
              <p class="text-xs text-silver-500 dark:text-silver-400">Aktuálně přihlášen jako <span class="font-mono font-bold text-vintage-grape-500"><%= currentUser %></span></p>
            </div>
            <div class="flex gap-3">
              <div class="relative flex-1">
                <i class="fas fa-user absolute left-4 top-1/2 -translate-y-1/2 text-silver-400 dark:text-silver-500"></i>
                <input type="text" id="account_new_username" placeholder="Nové uživatelské jméno"
                  class="w-full pl-11 pr-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 focus:ring-1 focus:ring-vintage-grape-500 transition-all">
              </div>
              <button id="saveUsernameBtn" onclick="saveUsername()"
                class="px-5 py-3 bg-midnight-violet-700 hover:bg-midnight-violet-600 text-white text-sm font-semibold rounded-lg transition-colors flex items-center gap-2 shrink-0">
                <i class="fas fa-check"></i> Uložit
              </button>
            </div>
          </div>

          <hr class="border-ash-grey-200 dark:border-midnight-violet-800">

          <!-- Změna hesla -->
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-midnight-violet-900 dark:text-silver-200 mb-0.5">Změna hesla</label>
              <p class="text-xs text-silver-500 dark:text-silver-400">Zadejte aktuální heslo pro ověření, pak nové heslo (min. 6 znaků).</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div class="relative">
                <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-silver-400 dark:text-silver-500"></i>
                <input type="password" id="account_current_password" placeholder="Aktuální heslo"
                  class="w-full pl-11 pr-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 focus:ring-1 focus:ring-vintage-grape-500 transition-all">
              </div>
              <div class="relative">
                <i class="fas fa-key absolute left-4 top-1/2 -translate-y-1/2 text-silver-400 dark:text-silver-500"></i>
                <input type="password" id="account_new_password" placeholder="Nové heslo"
                  class="w-full pl-11 pr-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 focus:ring-1 focus:ring-vintage-grape-500 transition-all">
              </div>
              <div class="relative">
                <i class="fas fa-key absolute left-4 top-1/2 -translate-y-1/2 text-silver-400 dark:text-silver-500"></i>
                <input type="password" id="account_confirm_password" placeholder="Potvrzení hesla"
                  class="w-full pl-11 pr-4 py-3 bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-sm text-gray-900 dark:text-silver-100 dark:placeholder-silver-600 focus:outline-none focus:border-vintage-grape-500 focus:ring-1 focus:ring-vintage-grape-500 transition-all">
              </div>
            </div>
            <div class="flex justify-end">
              <button id="savePasswordBtn" onclick="savePassword()"
                class="px-6 py-2.5 bg-vintage-grape-600 hover:bg-vintage-grape-700 text-white font-semibold rounded-lg shadow-sm transition-colors flex items-center gap-2">
                <i class="fas fa-lock"></i> Změnit heslo
              </button>
            </div>
          </div>

          <!-- Odhlášení -->
          <hr class="border-ash-grey-200 dark:border-midnight-violet-800">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-midnight-violet-900 dark:text-silver-200">Odhlášení</p>
              <p class="text-xs text-silver-500 dark:text-silver-400">Ukončí aktuální přihlášenou relaci.</p>
            </div>
            <form method="POST" action="/logout">
              <button type="submit" class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors flex items-center gap-2 text-sm">
                <i class="fas fa-sign-out-alt"></i> Odhlásit se
              </button>
            </form>
          </div>

        </div>
      </div>

    </div>
  </main>
</div>

<!-- Overlay for mobile sidebar -->
<div id="sidebarOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden lg:hidden"></div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/components/modals.js"></script>
<script src="/js/components/toast.js"></script>
<script type="module" src="/js/pages/settings/main.js"></script>
<script src="/js/common/utils.js"></script>
<script src="/js/components/header.js"></script> 

</body>
</html>