<!-- Server API Key Modal -->
<div id="serverApiKeyModal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-midnight-violet-950/40 backdrop-blur-sm">
  <div class="w-full max-w-md bg-white dark:bg-midnight-violet-900 rounded-xl shadow-2xl border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800">
      <div class="flex items-center gap-2">
        <i class="fas fa-key text-vintage-grape-400"></i>
        <h3 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-50">API klíč serveru</h3>
      </div>
      <button id="serverApiKeyClose" class="p-2 text-silver-400 hover:text-silver-700 dark:hover:text-silver-100 transition-colors rounded-lg hover:bg-ash-grey-100 dark:hover:bg-midnight-violet-800">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="p-6 space-y-4">
      <p class="text-sm text-silver-500 dark:text-silver-400">Zadejte vlastní klíč, nebo nechte pole prázdné pro automatické vygenerování UUID.</p>
      <div class="relative">
        <input id="serverApiKeyInput" type="text" placeholder="ponechte prázdné = generovat UUID"
          class="w-full px-4 py-3 font-mono text-sm bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-gray-900 dark:text-silver-100 focus:outline-none focus:border-vintage-grape-500 focus:ring-1 focus:ring-vintage-grape-500 transition-all" />
      </div>
      <div id="serverApiKeyError" class="hidden text-sm text-red-500 flex items-center gap-2">
        <i class="fas fa-exclamation-circle"></i><span></span>
      </div>
    </div>
    <div class="flex justify-end gap-3 px-6 pb-6">
      <button id="serverApiKeyCancelBtn" class="px-5 py-2.5 rounded-lg bg-ash-grey-200 dark:bg-midnight-violet-800 text-ash-grey-800 dark:text-silver-300 font-medium hover:bg-ash-grey-300 dark:hover:bg-midnight-violet-700 transition-colors">Zrušit</button>
      <button id="serverApiKeySaveBtn" class="px-5 py-2.5 rounded-lg bg-vintage-grape-600 hover:bg-vintage-grape-700 text-white font-semibold transition-colors flex items-center gap-2">
        <i class="fas fa-save"></i> Uložit
      </button>
    </div>
  </div>
</div>
<%- include('partials/common/toastNotification') %>

