<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Správa Serverů - IoT Control</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'ash-grey': {'50':'#f2f3f1','100':'#e6e7e4','200':'#ccd0c8','300':'#b3b8ad','400':'#9aa092','500':'#808877','600':'#676d5f','700':'#4d5247','800':'#33372f','900':'#1a1b18','950':'#121311'},
            'silver': {'50':'#f2f3f2','100':'#e5e6e5','200':'#cbcdcb','300':'#b1b4b1','400':'#979b97','500':'#7d827d','600':'#646864','700':'#4b4e4b','800':'#323432','900':'#191a19','950':'#111211'},
            'vintage-grape': {'50':'#f3f0f4','100':'#e7e2e9','200':'#cfc4d4','300':'#b7a7be','400':'#a08aa8','500':'#886c93','600':'#6d5775','700':'#514158','800':'#362b3b','900':'#1b161d','950':'#130f15'},
            'midnight-violet': {'50':'#f3eff5','100':'#e8e0eb','200':'#d0c1d7','300':'#b9a2c3','400':'#a183af','500':'#8a639c','600':'#6e507c','700':'#533c5d','800':'#37283e','900':'#1c141f','950':'#130e16'}
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-ash-grey-50 min-h-screen">

  <aside id="sidebar" class="fixed top-0 left-0 h-full w-64 bg-midnight-violet-900 shadow-2xl transition-all duration-300 ease-in-out z-40">
    <div class="flex flex-col h-full">
      
      <div class="p-6 border-b border-midnight-violet-800">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3 overflow-hidden">
            <div class="w-10 h-10 bg-gradient-to-br from-vintage-grape-400 to-midnight-violet-500 rounded-lg shadow-lg flex-shrink-0"></div>
            <span class="text-ash-grey-50 font-bold text-lg whitespace-nowrap">IoT Control</span>
          </div>
          <button id="closeSidebar" class="text-ash-grey-300 hover:text-ash-grey-50 lg:hidden">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>

      <nav class="flex-1 overflow-y-auto p-4">
        <div class="space-y-6">

          <div>
            <div class="flex items-center justify-between mb-3 pr-2">
              <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider">Moje Servery</h3>
              <button id="addServerOpen" type="button" class="p-1.5 text-ash-grey-400 hover:text-vintage-grape-400 transition-colors" title="Přidat server">
                <i class="fas fa-plus"></i>
              </button>
            </div>

            <div id="serverListSidebar" class="space-y-1">
              <button class="w-full flex items-center justify-between px-3 py-2 rounded-lg text-white bg-midnight-violet-800 transition group" data-server-id="1">
                <div class="flex items-center space-x-3 overflow-hidden flex-1">
                  <i class="fas fa-server text-vintage-grape-400 flex-shrink-0"></i>
                  <span class="text-[14px] whitespace-nowrap overflow-hidden text-ellipsis flex-1 text-left font-medium">Debian Server</span>
                </div>
              </button>

              <button class="w-full flex items-center justify-between px-3 py-2 rounded-lg text-ash-grey-400 hover:bg-midnight-violet-800 hover:text-white transition group" data-server-id="2">
                <div class="flex items-center space-x-3 overflow-hidden flex-1">
                  <i class="fas fa-server text-vintage-grape-400 opacity-50 group-hover:opacity-100 flex-shrink-0"></i>
                  <span class="text-[14px] whitespace-nowrap overflow-hidden text-ellipsis flex-1 text-left font-medium">Ubuntu DB</span>
                </div>
              </button>
            </div>
          </div>

          <div>
            <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider mb-3">Akce</h3>
            <div class="space-y-1">
              <button class="w-full flex items-center space-x-3 px-4 py-2 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 transition">
                <i class="fas fa-sync-alt w-4 flex-shrink-0"></i>
                <span class="whitespace-nowrap">Test připojení (Ping)</span>
              </button>
            </div>
          </div>

        </div>
      </nav>

      <div class="p-4 border-t border-midnight-violet-800">
        <div class="flex items-center space-x-3 px-4 py-2">
          <div class="w-8 h-8 bg-vintage-grape-600 rounded-full flex items-center justify-center">
            <span class="text-ash-grey-50 text-sm font-semibold">U</span>
          </div>
          <div class="flex-1">
            <p class="text-ash-grey-50 text-sm font-medium">Admin</p>
            <p class="text-ash-grey-400 text-xs">admin@iot.local</p>
          </div>
          <a href="/logout" title="Odhlásit se" class="ml-2 p-2 rounded-full hover:bg-midnight-violet-700 transition text-ash-grey-300 hover:text-red-400">
            <i class="fas fa-sign-out-alt"></i>
          </a>
        </div>
      </div>
    </div>
  </aside>

  <div id="mainContent" class="lg:ml-64 transition-all duration-300">
    
    <header class="bg-white shadow-sm border-b border-ash-grey-200 sticky top-0 z-30">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <h1 class="text-2xl font-bold text-midnight-violet-900">Správa Serveru</h1>
          </div>
          <div class="flex items-center space-x-4">
            <a href="/dashboard" class="text-silver-500 hover:text-midnight-violet-700 transition font-semibold text-sm flex items-center gap-2">
              <i class="fas fa-home"></i> <span class="hidden md:inline">Dashboard</span>
            </a>
          </div>
        </div>
      </div>
    </header>

   <main class="p-6 max-w-7xl mx-auto space-y-10">
      
  <div class="server-block">
    
    <div class="bg-white rounded-t-xl shadow-sm border border-ash-grey-200 p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative z-10">
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 bg-gradient-to-br from-midnight-violet-700 to-vintage-grape-600 rounded-xl flex items-center justify-center shadow-md shrink-0">
          <i class="fas fa-server text-2xl text-white"></i>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-midnight-violet-900">Debian Server (Main)</h2>
          <div class="flex items-center gap-4 mt-1 text-sm text-silver-600">
            <span class="flex items-center gap-1 font-mono bg-ash-grey-100 px-2 py-0.5 rounded border border-ash-grey-200"><i class="fas fa-network-wired text-xs"></i> 192.168.1.100</span>
            <span class="flex items-center gap-1 text-green-600 font-medium"><i class="fas fa-circle text-[8px] animate-pulse"></i> Online</span>
          </div>
        </div>
      </div>
      
      <div class="flex gap-2 w-full md:w-auto">
        <button class="addCommandOpen flex-1 md:flex-none px-4 py-2 bg-vintage-grape-50 border border-vintage-grape-200 text-vintage-grape-700 font-semibold rounded-lg hover:bg-vintage-grape-100 transition-colors shadow-sm flex items-center justify-center gap-2" data-server-id="1">
          <i class="fas fa-plus"></i> Nová akce
        </button>
        <button class="flex-none px-4 py-2 bg-white border border-ash-grey-300 text-midnight-violet-900 font-semibold rounded-lg hover:bg-ash-grey-50 transition-colors shadow-sm" title="Upravit server">
          <i class="fas fa-pen text-silver-400"></i>
        </button>
        <button class="flex-none px-4 py-2 bg-white border border-red-200 text-red-600 font-semibold rounded-lg hover:bg-red-50 transition-colors shadow-sm" title="Smazat server">
          <i class="fas fa-trash-alt"></i>
        </button>
      </div>
    </div>

    <div class="bg-ash-grey-100/50 rounded-b-xl shadow-sm border border-ash-grey-200 border-t-0 p-6 w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <div class="group relative bg-white border border-ash-grey-200 rounded-xl p-5 hover:border-vintage-grape-400 transition-all shadow-sm hover:shadow-md cursor-pointer flex flex-col justify-between min-h-[130px]">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-silver-50 border border-ash-grey-100 rounded-lg flex items-center justify-center shrink-0">
              <i class="fas fa-sync text-sm text-blue-500"></i>
            </div>
            <span class="font-bold text-midnight-violet-900 text-base truncate">Restart Apache</span>
          </div>
          <p class="mt-4 text-[11px] font-mono text-ash-grey-500 truncate bg-ash-grey-50 px-3 py-2 rounded border border-ash-grey-100">sudo systemctl restart apache2</p>
          <div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="p-1.5 bg-white text-silver-500 hover:text-vintage-grape-600 rounded border border-ash-grey-200 shadow-sm" title="Spustit"><i class="fas fa-play text-xs"></i></button>
            <button class="p-1.5 bg-white text-silver-500 hover:text-vintage-grape-600 rounded border border-ash-grey-200" title="Upravit"><i class="fas fa-edit text-xs"></i></button>
            <button class="p-1.5 bg-white text-silver-500 hover:text-red-500 rounded border border-ash-grey-200" title="Smazat"><i class="fas fa-trash text-xs"></i></button>
          </div>
        </div>

        <div class="group relative bg-white border border-ash-grey-200 rounded-xl p-5 hover:border-vintage-grape-400 transition-all shadow-sm hover:shadow-md cursor-pointer flex flex-col justify-between min-h-[130px]">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-silver-50 border border-ash-grey-100 rounded-lg flex items-center justify-center shrink-0">
              <i class="fas fa-broom text-sm text-yellow-600"></i>
            </div>
            <span class="font-bold text-midnight-violet-900 text-base truncate">Vyčistit Logy</span>
          </div>
          <p class="mt-4 text-[11px] font-mono text-ash-grey-500 truncate bg-ash-grey-50 px-3 py-2 rounded border border-ash-grey-100">sudo journalctl --vacuum-time=1d</p>
          <div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="p-1.5 bg-white text-silver-500 hover:text-vintage-grape-600 rounded border border-ash-grey-200 shadow-sm" title="Spustit"><i class="fas fa-play text-xs"></i></button>
            <button class="p-1.5 bg-white text-silver-500 hover:text-vintage-grape-600 rounded border border-ash-grey-200" title="Upravit"><i class="fas fa-edit text-xs"></i></button>
            <button class="p-1.5 bg-white text-silver-500 hover:text-red-500 rounded border border-ash-grey-200" title="Smazat"><i class="fas fa-trash text-xs"></i></button>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="server-block">
    
    <div class="bg-white rounded-t-xl shadow-sm border border-ash-grey-200 p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative z-10">
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 bg-gradient-to-br from-ash-grey-500 to-silver-600 rounded-xl flex items-center justify-center shadow-md shrink-0">
          <i class="fas fa-database text-2xl text-white"></i>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-midnight-violet-900">Ubuntu DB Node</h2>
          <div class="flex items-center gap-4 mt-1 text-sm text-silver-600">
            <span class="flex items-center gap-1 font-mono bg-ash-grey-100 px-2 py-0.5 rounded border border-ash-grey-200"><i class="fas fa-network-wired text-xs"></i> 10.0.0.55</span>
            <span class="flex items-center gap-1 text-red-500 font-medium"><i class="fas fa-circle text-[8px]"></i> Offline</span>
          </div>
        </div>
      </div>
      
      <div class="flex gap-2 w-full md:w-auto">
        <button class="addCommandOpen flex-1 md:flex-none px-4 py-2 bg-vintage-grape-50 border border-vintage-grape-200 text-vintage-grape-700 font-semibold rounded-lg hover:bg-vintage-grape-100 transition-colors shadow-sm flex items-center justify-center gap-2" data-server-id="2">
          <i class="fas fa-plus"></i> Nová akce
        </button>
        <button class="flex-none px-4 py-2 bg-white border border-ash-grey-300 text-midnight-violet-900 font-semibold rounded-lg hover:bg-ash-grey-50 transition-colors shadow-sm" title="Upravit server">
          <i class="fas fa-pen text-silver-400"></i>
        </button>
        <button class="flex-none px-4 py-2 bg-white border border-red-200 text-red-600 font-semibold rounded-lg hover:bg-red-50 transition-colors shadow-sm" title="Smazat server">
          <i class="fas fa-trash-alt"></i>
        </button>
      </div>
    </div>

    <div class="bg-ash-grey-100/50 rounded-b-xl shadow-sm border border-ash-grey-200 border-t-0 p-6 w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <div class="group relative bg-white border border-ash-grey-200 rounded-xl p-5 hover:border-vintage-grape-400 transition-all shadow-sm hover:shadow-md cursor-pointer flex flex-col justify-between min-h-[130px]">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-silver-50 border border-ash-grey-100 rounded-lg flex items-center justify-center shrink-0">
              <i class="fas fa-power-off text-sm text-green-600"></i>
            </div>
            <span class="font-bold text-midnight-violet-900 text-base truncate">Probuzení (WoL)</span>
          </div>
          <p class="mt-4 text-[11px] font-mono text-ash-grey-500 truncate bg-ash-grey-50 px-3 py-2 rounded border border-ash-grey-100">MAC: 1A:2B:3C:4D:5E:6F</p>
          <div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="p-1.5 bg-white text-silver-500 hover:text-vintage-grape-600 rounded border border-ash-grey-200 shadow-sm" title="Probudit"><i class="fas fa-play text-xs"></i></button>
            <button class="p-1.5 bg-white text-silver-500 hover:text-vintage-grape-600 rounded border border-ash-grey-200" title="Upravit"><i class="fas fa-edit text-xs"></i></button>
            <button class="p-1.5 bg-white text-silver-500 hover:text-red-500 rounded border border-ash-grey-200" title="Smazat"><i class="fas fa-trash text-xs"></i></button>
          </div>
        </div>

        <div class="flex items-center justify-center p-6 border-2 border-dashed border-ash-grey-200 rounded-xl text-ash-grey-400 bg-white/50 min-h-[130px]">
          <span class="text-xs font-semibold">Tento server nemá další akce</span>
        </div>

      </div>
    </div>
  </div>

</main>
  </div>

  <div id="addServerModal" class="fixed inset-0 z-50 flex items-center justify-center bg-midnight-violet-900/40 backdrop-blur-sm hidden transition-opacity">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md border border-ash-grey-200 overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-ash-grey-100 bg-silver-50">
        <h3 class="text-lg font-bold text-midnight-violet-900 flex items-center gap-2">
          <i class="fas fa-server text-vintage-grape-600"></i> Přidat nový server
        </h3>
        <button id="addServerClose" class="text-ash-grey-400 hover:text-red-500 transition-colors">
          <i class="fas fa-times text-lg"></i>
        </button>
      </div>
      <div class="p-6">
        <form id="addServerForm" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">Název serveru</label>
            <input type="text" name="name" placeholder="např. DB Node" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm text-midnight-violet-900 focus:outline-none focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-400">
          </div>
          <div>
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">IP adresa</label>
            <input type="text" name="ip" placeholder="192.168.1.x" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm font-mono text-ash-grey-600 focus:outline-none focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-400">
          </div>
          <div>
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">API Klíč (Volitelné)</label>
            <input type="text" name="api_key" placeholder="sk_live_..." class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm font-mono text-ash-grey-600 focus:outline-none focus:border-vintage-grape-400 focus:ring-1 focus:ring-vintage-grape-400">
          </div>
        </form>
      </div>
      <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-ash-grey-100 bg-silver-50">
        <button id="addServerCancel" class="px-4 py-2 text-sm font-semibold text-ash-grey-600 hover:text-midnight-violet-900 hover:bg-ash-grey-100 rounded-lg">Zrušit</button>
        <button id="addServerSubmit" class="px-5 py-2 text-sm font-semibold text-white bg-vintage-grape-600 hover:bg-vintage-grape-700 rounded-lg shadow-sm">Uložit server</button>
      </div>
    </div>
  </div>

  <div id="addCommandModal" class="fixed inset-0 z-50 flex items-center justify-center bg-midnight-violet-900/40 backdrop-blur-sm hidden transition-opacity">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg border border-ash-grey-200 overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-ash-grey-100 bg-silver-50">
        <h3 class="text-lg font-bold text-midnight-violet-900 flex items-center gap-2">
          <i class="fas fa-terminal text-vintage-grape-600"></i> Přidat nový příkaz
        </h3>
        <button id="addCommandClose" class="text-ash-grey-400 hover:text-red-500 transition-colors">
          <i class="fas fa-times text-lg"></i>
        </button>
      </div>
      <div class="p-6">
        <form id="addCommandForm" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">Název akce</label>
            <input type="text" name="name" placeholder="např. Restart Apache" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm focus:outline-none focus:border-vintage-grape-400">
          </div>
          <div>
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">Typ akce</label>
            <select id="commandType" name="type" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm focus:outline-none focus:border-vintage-grape-400">
              <option value="shell" selected>Příkaz (Shell)</option>
              <option value="wol">Wake on LAN</option>
            </select>
          </div>
          <div id="shellInputWrapper">
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">Příkaz</label>
            <textarea name="command" rows="3" placeholder="sudo systemctl restart apache2" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm font-mono focus:outline-none focus:border-vintage-grape-400 resize-none"></textarea>
          </div>
          <div id="wolInputWrapper" class="hidden">
            <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">MAC adresa</label>
            <input type="text" name="macAddress" placeholder="00:1A:2B:3C:4D:5E" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm font-mono focus:outline-none focus:border-vintage-grape-400">
          </div>
        </form>
      </div>
      <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-ash-grey-100 bg-silver-50">
        <button id="addCommandCancel" class="px-4 py-2 text-sm font-semibold text-ash-grey-600 hover:text-midnight-violet-900 hover:bg-ash-grey-100 rounded-lg">Zrušit</button>
        <button id="addCommandSubmit" class="px-5 py-2 text-sm font-semibold text-white bg-vintage-grape-600 hover:bg-vintage-grape-700 rounded-lg shadow-sm">Uložit příkaz</button>
      </div>
    </div>
  </div>

</body>
</html>