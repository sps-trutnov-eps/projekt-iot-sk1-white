<%- include('partials/servers/head') %>
<%- include('partials/servers/sidebar') %>

<div id="mainContent" class="lg:ml-64 transition-all duration-300">
  <%- include('partials/servers/header') %>

  <main class="p-6 max-w-7xl mx-auto">

    <!-- Search Bar -->
    <div class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 p-4 mb-6 transition-colors duration-300">
      <div class="relative flex-1 max-w-md">
        <input
          type="text"
          id="searchServer"
          placeholder="Hledat server..."
          class="w-full pl-10 pr-4 py-2 bg-ash-grey-50 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-vintage-grape-500 focus:border-transparent dark:text-silver-100 dark:placeholder-silver-500"
        >
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-silver-400"></i>
      </div>
    </div>

    <!-- Servers List -->
    <div id="servers-container" class="space-y-10">
      <div class="flex justify-center py-20">
        <i class="fas fa-spinner fa-spin text-3xl text-vintage-grape-600"></i>
      </div>
    </div>

  </main>
</div>

<%- include('partials/servers/addServerModal') %>
<%- include('partials/servers/addCommandModal') %>

<%- include('partials/servers/editCommandModal') %>
<%- include('partials/servers/editServerModal') %>

<%- include('partials/servers/deleteModal') %>
<%- include('partials/common/toastNotification') %>

<script src="/socket.io/socket.io.js"></script>

<script src="/js/components/modals.js"></script>
<script src="/js/components/toast.js"></script>

<script type="module" src="/js/pages/servers/main.js"></script>
<script src="/js/common/utils.js"></script>
<script src="/js/components/header.js"></script>  

<%- include('partials/servers/footer') %>