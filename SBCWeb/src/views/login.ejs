<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            'ash-grey': {'50':'#f2f3f1','100':'#e6e7e4','200':'#ccd0c8','300':'#b3b8ad','400':'#9aa092','500':'#808877','600':'#676d5f','700':'#4d5247','800':'#33372f','900':'#1a1b18','950':'#121311'},
            'silver': {'50':'#f2f3f2','100':'#e5e6e5','200':'#cbcdcb','300':'#b1b4b1','400':'#979b97','500':'#7d827d','600':'#646864','700':'#4b4e4b','800':'#323432','900':'#191a19','950':'#111211'},
            'mauve-shadow': {'50':'#f4f0f3','100':'#e9e2e7','200':'#d3c5cf','300':'#bda8b7','400':'#a78ba0','500':'#916e88','600':'#74586d','700':'#574251','800':'#3a2c36','900':'#1d161b','950':'#140f13'},
            'vintage-grape': {'50':'#f3f0f4','100':'#e7e2e9','200':'#cfc4d4','300':'#b7a7be','400':'#a08aa8','500':'#886c93','600':'#6d5775','700':'#514158','800':'#362b3b','900':'#1b161d','950':'#130f15'},
            'midnight-violet': {'50':'#f3eff5','100':'#e8e0eb','200':'#d0c1d7','300':'#b9a2c3','400':'#a183af','500':'#8a639c','600':'#6e507c','700':'#533c5d','800':'#37283e','900':'#1c141f','950':'#130e16'}
          }
        }
      }
    }
  </script>
  <script>
    if (localStorage.getItem('ui_theme') === 'dark') {
      document.documentElement.classList.add('dark');
    }
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-ash-grey-100 dark:bg-midnight-violet-950 min-h-screen flex items-center justify-center transition-colors duration-300">

  <div class="w-full max-w-md px-4">

    <!-- Logo / hlavička -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-vintage-grape-400 to-midnight-violet-600 rounded-2xl shadow-xl mb-4">
        <i class="fas fa-microchip text-white text-2xl"></i>
      </div>
      <h1 class="text-3xl font-bold text-midnight-violet-900 dark:text-ash-grey-50">IoT Control Panel</h1>
      <p class="text-ash-grey-500 dark:text-ash-grey-400 mt-1 text-sm">Přihlaste se pro přístup do systému</p>
    </div>

    <!-- Přihlašovací karta -->
    <div class="bg-white dark:bg-midnight-violet-900 rounded-2xl shadow-2xl border border-ash-grey-200 dark:border-midnight-violet-800 p-8">

      <% if (error) { %>
      <div class="flex items-center gap-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 rounded-xl px-4 py-3 mb-6 text-sm">
        <i class="fas fa-exclamation-circle flex-shrink-0"></i>
        <span><%= error %></span>
      </div>
      <% } %>

      <form method="POST" action="/login" class="space-y-5">

        <!-- Uživatelské jméno -->
        <div>
          <label for="username" class="block text-sm font-medium text-ash-grey-700 dark:text-ash-grey-300 mb-1.5">
            Uživatelské jméno
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-ash-grey-400 dark:text-ash-grey-500">
              <i class="fas fa-user text-sm"></i>
            </span>
            <input
              type="text"
              id="username"
              name="username"
              autocomplete="username"
              required
              class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-ash-grey-300 dark:border-midnight-violet-700 bg-ash-grey-50 dark:bg-midnight-violet-800 text-ash-grey-900 dark:text-ash-grey-100 placeholder-ash-grey-400 focus:outline-none focus:ring-2 focus:ring-vintage-grape-400 dark:focus:ring-vintage-grape-500 transition"
              placeholder="admin"
            />
          </div>
        </div>

        <!-- Heslo -->
        <div>
          <label for="password" class="block text-sm font-medium text-ash-grey-700 dark:text-ash-grey-300 mb-1.5">
            Heslo
          </label>
          <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-ash-grey-400 dark:text-ash-grey-500">
              <i class="fas fa-lock text-sm"></i>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              required
              class="w-full pl-10 pr-10 py-2.5 rounded-xl border border-ash-grey-300 dark:border-midnight-violet-700 bg-ash-grey-50 dark:bg-midnight-violet-800 text-ash-grey-900 dark:text-ash-grey-100 placeholder-ash-grey-400 focus:outline-none focus:ring-2 focus:ring-vintage-grape-400 dark:focus:ring-vintage-grape-500 transition"
              placeholder="••••••••"
            />
            <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-3 flex items-center text-ash-grey-400 dark:text-ash-grey-500 hover:text-vintage-grape-500 transition" tabindex="-1">
              <i id="eyeIcon" class="fas fa-eye text-sm"></i>
            </button>
          </div>
        </div>

        <!-- Tlačítko přihlásit -->
        <button
          type="submit"
          class="w-full py-2.5 px-4 bg-gradient-to-r from-vintage-grape-500 to-midnight-violet-600 hover:from-vintage-grape-400 hover:to-midnight-violet-500 text-white font-semibold rounded-xl shadow-lg transition duration-200 focus:outline-none focus:ring-2 focus:ring-vintage-grape-400 focus:ring-offset-2 dark:focus:ring-offset-midnight-violet-900"
        >
          <i class="fas fa-sign-in-alt mr-2"></i>Přihlásit se
        </button>

      </form>
    </div>

    <p class="text-center text-xs text-ash-grey-400 dark:text-ash-grey-600 mt-6">
      Projekt IoT SK1 White &copy; <%= new Date().getFullYear() %>
    </p>
  </div>

  <script>
    function togglePassword() {
      const input = document.getElementById('password');
      const icon = document.getElementById('eyeIcon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>

</body>
</html>
