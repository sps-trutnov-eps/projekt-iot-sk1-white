<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Stránka nenalezena | IoT Control' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            'ash-grey': {'50':'#f2f3f1','100':'#e6e7e4','200':'#ccd0c8','300':'#b3b8ad','400':'#9aa092','500':'#808877','600':'#676d5f','700':'#4d5247','800':'#33372f','900':'#1a1b18','950':'#121311'},
            'vintage-grape': {'50':'#f3f0f4','100':'#e7e2e9','200':'#cfc4d4','300':'#b7a7be','400':'#a08aa8','500':'#886c93','600':'#6d5775','700':'#514158','800':'#362b3b','900':'#1b161d','950':'#130f15'},
            'midnight-violet': {'50':'#f3eff5','100':'#e8e0eb','200':'#d0c1d7','300':'#b9a2c3','400':'#a183af','500':'#8a639c','600':'#6e507c','700':'#533c5d','800':'#37283e','900':'#1c141f','950':'#130e16'}
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script>
    if (localStorage.getItem('ui_theme') === 'dark') {
        document.documentElement.classList.add('dark');
    }
  </script>
</head>
<body class="bg-ash-grey-50 dark:bg-midnight-violet-950 dark:text-silver-100 min-h-screen flex items-center justify-center font-sans antialiased transition-colors duration-300">
  
  <div class="max-w-md mx-auto px-4 w-full">
    <div class="bg-white dark:bg-midnight-violet-900 rounded-2xl shadow-xl border border-ash-grey-200 dark:border-midnight-violet-800 p-10 md:p-12 text-center transition-colors duration-300">
      
      <div class="w-20 h-20 bg-gradient-to-br from-midnight-violet-500 to-vintage-grape-600 rounded-2xl flex items-center justify-center text-white text-4xl mx-auto mb-6 shadow-lg">
        <i class="fas fa-ghost"></i>
      </div>
      
      <h1 class="text-6xl font-black text-midnight-violet-900 dark:text-silver-50 mb-4 tracking-tight">404</h1>
      <h2 class="text-2xl font-bold text-midnight-violet-800 dark:text-silver-100 mb-3">Stránka nenalezena</h2>
      <p class="text-ash-grey-500 dark:text-silver-400 font-medium mb-8 leading-relaxed">
        Omlouváme se, ale zřejmě jste zabloudili. Požadovaná stránka neexistuje nebo byla přesunuta.
      </p>
      
      <a href="/dashboard" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-vintage-grape-600 text-white rounded-lg font-semibold shadow-md hover:bg-vintage-grape-700 hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 w-full sm:w-auto">
        <i class="fas fa-arrow-left"></i>
        Zpět na Dashboard
      </a>
      
    </div>
  </div>

</body>
</html>