<!-- MCU Header -->
<header class="bg-white dark:bg-midnight-violet-900 shadow-sm border-b border-ash-grey-200 dark:border-midnight-violet-800 sticky top-0 z-30 transition-colors duration-300">
  <div class="px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Left Side -->
      <div class="flex items-center space-x-4">
        <h1 class="text-2xl font-bold text-midnight-violet-900 dark:text-silver-50">Seznam MCU</h1>
      </div>

      <!-- Right Side -->
      <div class="flex items-center space-x-4">

        <a href="/mcu" class="header-btn" title="MCU Controllers">
          <i class="fas fa-microchip w-5"></i>
          <span class="hidden md:inline">Mcus</span>
        </a>
        <a href="/server" class="header-btn" title="MCU Controllers">
          <i class="fas fa-server w-5"></i>
          <span class="hidden md:inline">Servers</span>
        </a>


        <!-- Notifications -->
        <div class="relative" id="notificationContainer">
    <button id="notificationBellBtn" class="header-btn relative p-2 text-silver-500 hover:text-midnight-violet-700 transition" title="Notifications">
        <i class="fas fa-bell text-xl"></i>
        <span id="notificationBadge" class="hidden absolute top-0 right-0 w-4 h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center border-2 border-white shadow-sm">
            0
        </span>
    </button>

    <div id="notificationDropdown" class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-midnight-violet-900 rounded-xl shadow-2xl border border-ash-grey-200 dark:border-midnight-violet-800 z-[100] overflow-hidden">
        <div class="px-4 py-3 border-b border-ash-grey-100 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex justify-between items-center">
            <h3 class="font-bold text-midnight-violet-900 dark:text-silver-100 text-sm flex items-center gap-2">
                <i class="fas fa-history text-vintage-grape-500"></i> Historie událostí
            </h3>
            <button id="clearNotificationsBtn" class="text-xs font-semibold text-silver-400 hover:text-red-500 transition-colors">
                Vymazat
            </button>
        </div>
        
        <div id="notificationList" class="max-h-72 overflow-y-auto p-2 bg-white dark:bg-midnight-violet-900">
            <div class="text-center text-sm text-silver-400 py-6" id="emptyNotifications">
                <i class="fas fa-bell-slash text-2xl mb-2 opacity-50 block"></i>
                Zatím vše běží jak má.
            </div>
        </div>
        
    </div>
</div>
<a href="/settings" class="header-btn" title="Nastavení">
  <i class="fas fa-cog text-xl"></i>
</a>

<!-- User dropdown -->
<div class="relative" id="userMenuContainer">
  <button id="userMenuBtn" class="flex items-center gap-2 pl-2 pr-3 py-1.5 rounded-lg hover:bg-ash-grey-100 dark:hover:bg-midnight-violet-800 transition-colors group" title="Účet">
    <div class="w-8 h-8 rounded-full bg-vintage-grape-600 flex items-center justify-center text-white text-sm font-bold shrink-0">
      <%= (currentUser || 'U').charAt(0).toUpperCase() %>
    </div>
    <span class="hidden md:block text-sm font-medium text-midnight-violet-800 dark:text-silver-200 max-w-[100px] truncate"><%= currentUser || 'Uživatel' %></span>
    <i class="fas fa-chevron-down text-[10px] text-silver-400 group-hover:text-silver-600 transition-transform duration-200" id="userMenuChevron"></i>
  </button>

  <div id="userMenuDropdown" class="hidden absolute right-0 mt-2 w-44 bg-white dark:bg-midnight-violet-900 rounded-xl shadow-xl border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden z-[200]">
    <a href="/settings" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-midnight-violet-800 dark:text-silver-200 hover:bg-ash-grey-50 dark:hover:bg-midnight-violet-800 transition-colors">
      <i class="fas fa-cog w-4 text-silver-400"></i> Nastavení
    </a>
    <div class="border-t border-ash-grey-100 dark:border-midnight-violet-800"></div>
    <form method="POST" action="/logout">
      <button type="submit" class="w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
        <i class="fas fa-sign-out-alt w-4"></i> Odhlásit se
      </button>
    </form>
  </div>
</div>

<script>
  (() => {
    const btn = document.getElementById('userMenuBtn');
    const dropdown = document.getElementById('userMenuDropdown');
    const chevron = document.getElementById('userMenuChevron');
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = !dropdown.classList.contains('hidden');
      dropdown.classList.toggle('hidden', open);
      chevron.style.transform = open ? '' : 'rotate(180deg)';
    });
    document.addEventListener('click', () => {
      dropdown.classList.add('hidden');
      chevron.style.transform = '';
    });
  })();
</script>
      </div>
    </div>
  </div>
</header>
