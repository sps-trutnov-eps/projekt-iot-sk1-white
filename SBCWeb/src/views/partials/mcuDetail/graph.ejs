<div class="bg-white dark:bg-midnight-violet-900 p-6 rounded-xl border border-ash-grey-200 dark:border-midnight-violet-800 shadow-sm w-full transition-colors duration-300">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-6 gap-4">
        
        <div>
            <h3 id="chartTitle" class="font-bold text-midnight-violet-900 dark:text-silver-50 text-lg">Analýza dat</h3>
            <p class="text-xs text-silver-500">Vývoj hodnot v čase</p>
        </div>
        
        <div class="flex flex-wrap items-center gap-4 sm:gap-6">
            
            <div class="flex items-center gap-3">
                <label class="flex items-center gap-1 cursor-pointer">
                    <input type="radio" name="chartMetric" value="avg" checked onchange="updateChartMetric()" class="accent-vintage-grape-600 w-3 h-3">
                    <span class="text-xs text-gray-700 dark:text-silver-300">Avg</span>
                </label>
                
                <label class="flex items-center gap-1 cursor-pointer">
                    <input type="radio" name="chartMetric" value="min" onchange="updateChartMetric()" class="accent-blue-500 w-3 h-3">
                    <span class="text-xs text-gray-700 dark:text-silver-300">Min</span>
                </label>

                <label class="flex items-center gap-1 cursor-pointer">
                    <input type="radio" name="chartMetric" value="max" onchange="updateChartMetric()" class="accent-red-500 w-3 h-3">
                    <span class="text-xs text-gray-700 dark:text-silver-300">Max</span>
                </label>

                <div class="w-[1px] h-3 bg-gray-300 dark:bg-midnight-violet-700 mx-1"></div>

                <label class="flex items-center gap-1 cursor-pointer">
                    <input type="radio" name="chartMetric" value="all" onchange="updateChartMetric()" class="accent-vintage-grape-600 w-3 h-3">
                    <span class="text-xs text-gray-900 dark:text-silver-100 font-bold">Vše</span>
                </label>
            </div>

            <div class="flex bg-ash-grey-50 dark:bg-midnight-violet-800 p-1 rounded-lg border border-ash-grey-200 dark:border-midnight-violet-700">
                <button onclick="updateChart('now'); setActiveRange(this)" 
                    class="range-btn px-3 py-1 text-[10px] font-bold uppercase rounded-md text-silver-500 hover:bg-white/60 dark:hover:bg-midnight-violet-700/60 transition-all focus:outline-none">
                    30min
                </button>

                <button onclick="updateChart('1h'); setActiveRange(this)" 
                    class="range-btn px-3 py-1 text-[10px] font-bold uppercase rounded-md text-silver-500 hover:bg-white/60 dark:hover:bg-midnight-violet-700/60 transition-all focus:outline-none">
                    1h
                </button>

                <button onclick="updateChart('24h'); setActiveRange(this)" 
                    class="range-btn px-3 py-1 text-[10px] font-bold uppercase rounded-md bg-white dark:bg-midnight-violet-700 shadow-sm text-vintage-grape-600 transition-all focus:outline-none active-range">
                    24h
                </button>

                <button onclick="updateChart('7d'); setActiveRange(this)" 
                    class="range-btn px-3 py-1 text-[10px] font-bold uppercase rounded-md text-silver-500 hover:bg-white/60 dark:hover:bg-midnight-violet-700/60 transition-all focus:outline-none">
                    7d
                </button>
            </div>
        </div>
    </div>

    <div class="chart-window relative w-full h-[300px] rounded-xl overflow-hidden p-3">
        <canvas id="mainChart" class="relative z-10"></canvas>
    </div>
</div>

<style>
    .chart-window {
        background: radial-gradient(ellipse at 50% 55%, rgba(255,255,255,1) 0%, rgba(237,233,248,0.65) 100%);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.9),
            inset 0 -1px 0 rgba(124,58,237,0.06),
            inset 1px 0 0 rgba(255,255,255,0.6),
            inset -1px 0 0 rgba(255,255,255,0.6),
            0 2px 12px rgba(124,58,237,0.07);
        border: 1px solid rgba(196,186,220,0.45);
    }
    .dark .chart-window {
        background: radial-gradient(ellipse at 50% 55%, rgba(50,36,56,0.95) 0%, rgba(20,13,23,0.98) 100%);
        box-shadow:
            inset 0 1px 0 rgba(167,139,250,0.12),
            inset 0 -1px 0 rgba(0,0,0,0.3),
            inset 1px 0 0 rgba(167,139,250,0.06),
            inset -1px 0 0 rgba(167,139,250,0.06),
            0 2px 16px rgba(0,0,0,0.25);
        border: 1px solid rgba(55,40,62,0.9);
    }
</style>

<script>
    function setActiveRange(btn) {
        const buttons = btn.parentElement.querySelectorAll('.range-btn');
        buttons.forEach(b => {
            b.className = 'range-btn px-3 py-1 text-[10px] font-bold uppercase rounded-md text-silver-500 hover:bg-white/60 dark:hover:bg-midnight-violet-700/60 transition-all focus:outline-none';
        });
        btn.className = 'range-btn px-3 py-1 text-[10px] font-bold uppercase rounded-md bg-white dark:bg-midnight-violet-700 shadow-sm text-vintage-grape-600 transition-all focus:outline-none active-range';
    }
</script>