<!-- Inline Deck Configuration -->
<div class="bg-white dark:bg-midnight-violet-900 rounded-xl border border-ash-grey-200 dark:border-midnight-violet-800 shadow-sm overflow-hidden transition-colors duration-300">

    <!-- Header -->
    <div class="px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-silver-50 dark:bg-midnight-violet-900/50 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-vintage-grape-100 dark:bg-vintage-grape-900/50 text-vintage-grape-600 dark:text-vintage-grape-400 flex items-center justify-center">
                <i class="fas fa-tv"></i>
            </div>
            <h2 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-100"><%= t('deck.title') %></h2>
        </div>
        <div class="flex items-center gap-2">
            <button id="deckInlinePush" title="<%= t('deck.push') %>"
                class="px-3 py-1.5 rounded-lg text-xs font-medium bg-ash-grey-200 dark:bg-midnight-violet-800 text-ash-grey-700 dark:text-silver-300 hover:bg-ash-grey-300 dark:hover:bg-midnight-violet-700 transition-colors flex items-center gap-1.5">
                <i class="fas fa-satellite-dish"></i> <%= t('deck.push') %>
            </button>
            <button id="deckInlineSave" title="<%= t('deck.save') %>"
                class="px-3 py-1.5 rounded-lg text-xs font-medium bg-vintage-grape-600 text-white hover:bg-vintage-grape-700 transition-colors flex items-center gap-1.5">
                <i class="fas fa-save"></i> <%= t('deck.save') %>
            </button>
        </div>
    </div>

    <div class="p-6 space-y-6 bg-white dark:bg-[#150f18]">

        <div id="deckInlineError" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg">
            <p class="text-sm font-medium"></p>
        </div>

        <!-- Servers & Commands (tree) -->
        <div class="space-y-3">
            <div class="flex items-center gap-2">
                <i class="fas fa-server text-sm text-vintage-grape-500"></i>
                <h3 class="text-xs font-bold text-midnight-violet-900 dark:text-silver-200 uppercase tracking-widest"><%= t('deck.serversAndCommands') %></h3>
                <div class="ml-auto flex items-center gap-1.5">
                    <button type="button" data-check="server" class="deck-check-all px-2 py-1 rounded text-[10px] font-medium bg-vintage-grape-100 dark:bg-vintage-grape-900/30 text-vintage-grape-600 dark:text-vintage-grape-400 hover:bg-vintage-grape-200 dark:hover:bg-vintage-grape-800/40 transition">
                        <i class="fas fa-check-double mr-0.5"></i> <%= t('deck.checkAll') %>
                    </button>
                    <button type="button" data-uncheck="server" class="deck-uncheck-all px-2 py-1 rounded text-[10px] font-medium bg-ash-grey-100 dark:bg-midnight-violet-800 text-ash-grey-600 dark:text-silver-400 hover:bg-ash-grey-200 dark:hover:bg-midnight-violet-700 transition">
                        <i class="fas fa-times mr-0.5"></i> <%= t('deck.uncheckAll') %>
                    </button>
                </div>
            </div>
            <div id="deckInlineServers" class="space-y-3 max-h-[500px] overflow-y-auto custom-scrollbar">
                <p class="text-sm text-silver-400 italic"><%= t('deck.loading') %></p>
            </div>
        </div>

        <!-- MCU Sensors -->
        <div class="space-y-3">
            <div class="flex items-center gap-2">
                <i class="fas fa-microchip text-sm text-vintage-grape-500"></i>
                <h3 class="text-xs font-bold text-midnight-violet-900 dark:text-silver-200 uppercase tracking-widest"><%= t('deck.mcuSensors') %></h3>
                <div class="ml-auto flex items-center gap-1.5">
                    <button type="button" data-check="mcu" class="deck-check-all px-2 py-1 rounded text-[10px] font-medium bg-vintage-grape-100 dark:bg-vintage-grape-900/30 text-vintage-grape-600 dark:text-vintage-grape-400 hover:bg-vintage-grape-200 dark:hover:bg-vintage-grape-800/40 transition">
                        <i class="fas fa-check-double mr-0.5"></i> <%= t('deck.checkAll') %>
                    </button>
                    <button type="button" data-uncheck="mcu" class="deck-uncheck-all px-2 py-1 rounded text-[10px] font-medium bg-ash-grey-100 dark:bg-midnight-violet-800 text-ash-grey-600 dark:text-silver-400 hover:bg-ash-grey-200 dark:hover:bg-midnight-violet-700 transition">
                        <i class="fas fa-times mr-0.5"></i> <%= t('deck.uncheckAll') %>
                    </button>
                </div>
            </div>
            <div id="deckInlineMcus" class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-48 overflow-y-auto custom-scrollbar">
                <p class="text-sm text-silver-400 italic col-span-2"><%= t('deck.loading') %></p>
            </div>
        </div>

    </div>
</div>
