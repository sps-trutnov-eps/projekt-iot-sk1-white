<div class="bg-white dark:bg-midnight-violet-900 rounded-xl shadow-sm border border-ash-grey-200 dark:border-midnight-violet-800 p-6 relative overflow-hidden transition-colors duration-300">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="relative shrink-0">
                <div class="w-14 h-14 bg-gradient-to-br from-midnight-violet-700 to-vintage-grape-600 rounded-xl flex items-center justify-center shadow-lg">
                    <i class="fas fa-microchip text-2xl text-white"></i>
                </div>
                <span id="mcu-status-dot" class="absolute -bottom-1 -right-1 w-4 h-4 bg-gray-300 border-2 border-white dark:border-midnight-violet-900 rounded-full"></span>
            </div>
            <div>
                <div class="flex items-baseline gap-3 mb-1">
                    <h3 id="mcu-name" class="text-xl font-bold text-midnight-violet-900 dark:text-silver-50">Načítám...</h3>
                    <span id="mcu-status-text" class="text-xs font-bold text-gray-400 dark:text-silver-500 uppercase tracking-wider">Loading...</span>
                </div>
                <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-silver-600 dark:text-silver-400">
                    <span><span class="font-bold text-silver-400 dark:text-silver-500 text-xs uppercase mr-1">IP:</span><span id="mcu-ip" class="font-mono">---</span></span>
                    <span><span class="font-bold text-silver-400 dark:text-silver-500 text-xs uppercase mr-1">MAC:</span><span id="mcu-mac" class="font-mono">---</span></span>
                    <span class="flex items-center gap-1"><i class="fas fa-clock text-xs text-silver-400"></i> <span id="mcu-lastseen" class="text-xs">---</span></span>
                </div>
            </div>
        </div>
        
        <div id="api-key-container" class="flex items-center gap-2 bg-silver-50 dark:bg-midnight-violet-800 px-3 py-2 rounded-lg border border-silver-200 dark:border-midnight-violet-700 group hover:border-vintage-grape-300 transition-colors">
            <span class="text-[10px] font-bold text-silver-400 uppercase">API</span>
            <span id="mcu-api-key" class="font-mono text-xs text-gray-500 dark:text-silver-400 blur-[4px]" style="-webkit-text-security: disc;">
                loading...
            </span>            
            <div class="h-4 w-[1px] bg-silver-300 dark:bg-midnight-violet-700 mx-1"></div>
            
            <i id="api-key-eye" class="fas fa-eye text-silver-400 hover:text-midnight-violet-600 transition-colors p-1 cursor-pointer" title="Zobrazit/skrýt"></i>
            <i id="api-key-copy" class="fas fa-copy text-silver-400 hover:text-vintage-grape-600 transition-colors p-1 cursor-pointer" title="Kopírovat"></i>
            <i id="api-key-edit" class="fas fa-pen text-silver-400 hover:text-vintage-grape-500 transition-colors p-1 cursor-pointer" title="Upravit / vygenerovat klíč"></i>
        </div>
    </div>
</div>

<!-- API Key Modal -->
<div id="apiKeyModal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-midnight-violet-950/40 backdrop-blur-sm">
  <div class="w-full max-w-md bg-white dark:bg-midnight-violet-900 rounded-xl shadow-2xl border border-ash-grey-200 dark:border-midnight-violet-800 overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-ash-grey-200 dark:border-midnight-violet-800">
      <div class="flex items-center gap-2">
        <i class="fas fa-key text-vintage-grape-400"></i>
        <h3 class="text-lg font-bold text-midnight-violet-900 dark:text-silver-50">API klíč MCU</h3>
      </div>
      <button id="apiKeyModalClose" class="p-2 text-silver-400 hover:text-silver-700 dark:hover:text-silver-100 transition-colors rounded-lg hover:bg-ash-grey-100 dark:hover:bg-midnight-violet-800">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="p-6 space-y-4">
      <p class="text-sm text-silver-500 dark:text-silver-400">Zadejte vlastní klíč, nebo nechte pole prázdné pro automatické vygenerování UUID.</p>
      <div class="relative">
        <input id="apiKeyInput" type="text" placeholder="ponechte prázdné = generovat UUID"
          class="w-full px-4 py-3 font-mono text-sm bg-ash-grey-100 dark:bg-midnight-violet-800 border border-ash-grey-300 dark:border-midnight-violet-700 rounded-lg text-gray-900 dark:text-silver-100 focus:outline-none focus:border-vintage-grape-500 focus:ring-1 focus:ring-vintage-grape-500 transition-all" />
      </div>
      <div id="apiKeyModalError" class="hidden text-sm text-red-500 flex items-center gap-2">
        <i class="fas fa-exclamation-circle"></i><span></span>
      </div>
    </div>
    <div class="flex justify-end gap-3 px-6 pb-6">
      <button id="apiKeyModalCancel" class="px-5 py-2.5 rounded-lg bg-ash-grey-200 dark:bg-midnight-violet-800 text-ash-grey-800 dark:text-silver-300 font-medium hover:bg-ash-grey-300 dark:hover:bg-midnight-violet-700 transition-colors">Zrušit</button>
      <button id="apiKeyModalSave" class="px-5 py-2.5 rounded-lg bg-vintage-grape-600 hover:bg-vintage-grape-700 text-white font-semibold transition-colors flex items-center gap-2">
        <i class="fas fa-save"></i> Uložit
      </button>
    </div>
  </div>
</div>