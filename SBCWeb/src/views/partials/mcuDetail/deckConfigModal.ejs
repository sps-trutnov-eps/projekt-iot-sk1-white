<div id="deckConfigModal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-midnight-violet-950/40 backdrop-blur-sm">

    <div class="relative w-full max-w-3xl flex flex-col bg-silver-50 dark:bg-[#150f18] rounded-xl shadow-2xl overflow-hidden max-h-[90vh] transition-colors duration-300">

        <!-- Header -->
        <div class="flex items-center justify-between p-6 border-b border-ash-grey-200 dark:border-midnight-violet-800 bg-white dark:bg-midnight-violet-900 shrink-0">
            <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2">
                    <i class="fas fa-tv text-vintage-grape-600 dark:text-vintage-grape-400 text-xl"></i>
                    <h2 class="text-2xl font-bold tracking-tight text-midnight-violet-900 dark:text-silver-50">Deck Konfigurace</h2>
                </div>
                <p class="text-sm text-gray-500 dark:text-silver-400">Vyberte servery, příkazy a MCU senzory, které tento deck zobrazí.</p>
            </div>
            <button type="button" id="deckConfigClose" class="text-gray-400 dark:text-silver-400 hover:text-gray-600 dark:hover:text-silver-100 transition-colors p-2 rounded-lg hover:bg-ash-grey-100 dark:hover:bg-midnight-violet-800">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="flex-1 overflow-y-auto p-6 space-y-6 bg-silver-50 dark:bg-[#150f18]">

            <div id="deckConfigError" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg">
                <p class="text-sm font-medium"></p>
            </div>

            <!-- Servery -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <i class="fas fa-server text-vintage-grape-500"></i>
                    <h3 class="text-sm font-bold text-midnight-violet-900 dark:text-silver-200 uppercase tracking-widest">Servery</h3>
                    <button type="button" id="deckSelectAllServers" class="ml-auto text-xs text-vintage-grape-500 hover:text-vintage-grape-700 transition">Vybrat vše</button>
                </div>
                <div id="deckServersList" class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-40 overflow-y-auto custom-scrollbar">
                    <p class="text-sm text-silver-400 italic">Načítání...</p>
                </div>
            </div>

            <!-- Příkazy -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <i class="fas fa-terminal text-vintage-grape-500"></i>
                    <h3 class="text-sm font-bold text-midnight-violet-900 dark:text-silver-200 uppercase tracking-widest">Příkazy</h3>
                    <button type="button" id="deckSelectAllCommands" class="ml-auto text-xs text-vintage-grape-500 hover:text-vintage-grape-700 transition">Vybrat vše</button>
                </div>
                <div id="deckCommandsList" class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-40 overflow-y-auto custom-scrollbar">
                    <p class="text-sm text-silver-400 italic">Načítání...</p>
                </div>
            </div>

            <!-- MCU Senzory -->
            <div class="space-y-3">
                <div class="flex items-center gap-2">
                    <i class="fas fa-microchip text-vintage-grape-500"></i>
                    <h3 class="text-sm font-bold text-midnight-violet-900 dark:text-silver-200 uppercase tracking-widest">MCU Senzory</h3>
                    <button type="button" id="deckSelectAllMcus" class="ml-auto text-xs text-vintage-grape-500 hover:text-vintage-grape-700 transition">Vybrat vše</button>
                </div>
                <div id="deckMcusList" class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-40 overflow-y-auto custom-scrollbar">
                    <p class="text-sm text-silver-400 italic">Načítání...</p>
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="p-6 border-t border-ash-grey-200 dark:border-midnight-violet-800 bg-white dark:bg-midnight-violet-900 flex items-center gap-3 shrink-0">
            <button type="button" id="deckPushConfig"
                class="px-4 py-2.5 rounded-lg bg-ash-grey-200 dark:bg-midnight-violet-800 text-ash-grey-800 dark:text-silver-300 font-medium hover:bg-ash-grey-300 dark:hover:bg-midnight-violet-700 transition-colors flex items-center gap-2 text-sm"
                title="Odeslat aktuální konfiguraci na deck přes MQTT">
                <i class="fas fa-satellite-dish"></i>
                Push
            </button>
            <div class="flex-1"></div>
            <button type="button" id="deckConfigCancel"
                class="px-6 py-2.5 rounded-lg bg-ash-grey-200 dark:bg-midnight-violet-800 text-ash-grey-800 dark:text-silver-300 font-medium hover:bg-ash-grey-300 dark:hover:bg-midnight-violet-700 transition-colors">
                Zrušit
            </button>
            <button type="button" id="deckConfigSave"
                class="px-6 py-2.5 rounded-lg bg-vintage-grape-600 text-white font-medium hover:bg-vintage-grape-700 transition-colors flex items-center gap-2">
                <i class="fas fa-save"></i>
                Uložit
            </button>
        </div>
    </div>
</div>