<div id="editServerModal" class="fixed inset-0 z-50 flex items-center justify-center bg-midnight-violet-900/40 backdrop-blur-sm hidden transition-opacity">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-md border border-ash-grey-200 overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-ash-grey-100 bg-silver-50">
      <h3 class="text-lg font-bold text-midnight-violet-900 flex items-center gap-2">
        <i class="fas fa-pen text-vintage-grape-600"></i> Upravit server
      </h3>
      <button type="button" id="editServerClose" class="text-ash-grey-400 hover:text-red-500 transition-colors"><i class="fas fa-times text-lg"></i></button>
    </div>
    <div class="p-6">
      <div id="editServerError" class="hidden mb-4 p-3 bg-red-50 text-red-600 border border-red-200 rounded-lg text-sm flex items-center gap-2"><i class="fas fa-exclamation-circle"></i><p></p></div>
      <form id="editServerForm" class="space-y-4">
        <input type="hidden" name="id" id="editServerId">
        <div>
          <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">Název serveru</label>
          <input type="text" name="name" id="editServerName" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">IP adresa</label>
          <input type="text" name="ip" id="editServerIp" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm font-mono" required>
        </div>
        <div>
          <label class="block text-sm font-semibold text-midnight-violet-900 mb-1">API Klíč (Volitelné)</label>
          <input type="text" name="api_key" id="editServerApiKey" class="w-full px-4 py-2 bg-silver-50 border border-ash-grey-200 rounded-lg text-sm font-mono">
        </div>
      </form>
    </div>
    <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-ash-grey-100 bg-silver-50">
      <button type="button" id="editServerCancel" class="px-4 py-2 text-sm font-semibold text-ash-grey-600 hover:bg-ash-grey-100 rounded-lg">Zrušit</button>
      <button type="submit" id="editServerSubmit" form="editServerForm" class="px-5 py-2 text-sm font-semibold text-white bg-vintage-grape-600 hover:bg-vintage-grape-700 rounded-lg">Uložit změny</button>
    </div>
  </div>
</div>