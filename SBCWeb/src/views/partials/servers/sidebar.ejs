<aside id="sidebar" class="fixed top-0 left-0 h-full w-64 bg-midnight-violet-900 shadow-2xl transition-all duration-300 ease-in-out z-40">
  <div class="flex flex-col h-full">

    <!-- Header -->
    <div class="p-6 border-b border-midnight-violet-800 shrink-0">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3 overflow-hidden">
          <div class="w-10 h-10 bg-gradient-to-br from-vintage-grape-400 to-midnight-violet-500 rounded-lg shadow-lg flex-shrink-0"></div>
          <span class="text-ash-grey-50 font-bold text-lg whitespace-nowrap">IoT Control</span>
        </div>
        <button id="closeSidebar" class="text-ash-grey-300 hover:text-ash-grey-50 lg:hidden">
          <i class="fas fa-times"></i>
        </button>
      </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 overflow-y-auto p-4 custom-scrollbar">
      <div class="space-y-8">

        <!-- Quick Filters - Status -->
        <div>
          <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider mb-3"><%= t('servers.quickFilters') %></h3>
          <div class="space-y-1">
            <button class="quick-filter active w-full flex items-center justify-between px-4 py-2 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 transition" data-filter="all">
              <div class="flex items-center space-x-3 overflow-hidden">
                <i class="fas fa-list w-4 flex-shrink-0"></i>
                <span class="whitespace-nowrap"><%= t('servers.filterAll') %></span>
              </div>
              <span class="text-xs bg-midnight-violet-700 px-2 py-0.5 rounded-full" id="countAll">-</span>
            </button>
            <button class="quick-filter w-full flex items-center justify-between px-4 py-2 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 transition" data-filter="online">
              <div class="flex items-center space-x-3 overflow-hidden">
                <span class="w-2 h-2 bg-green-400 rounded-full flex-shrink-0"></span>
                <span class="whitespace-nowrap"><%= t('servers.filterOnline') %></span>
              </div>
              <span class="text-xs bg-green-900 text-green-300 px-2 py-0.5 rounded-full" id="countOnline">-</span>
            </button>
            <button class="quick-filter w-full flex items-center justify-between px-4 py-2 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 transition" data-filter="offline">
              <div class="flex items-center space-x-3 overflow-hidden">
                <span class="w-2 h-2 bg-red-400 rounded-full flex-shrink-0"></span>
                <span class="whitespace-nowrap"><%= t('servers.filterOffline') %></span>
              </div>
              <span class="text-xs bg-red-900 text-red-300 px-2 py-0.5 rounded-full" id="countOffline">-</span>
            </button>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-3 pr-2">
            <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider"><%= t('servers.actions') %></h3>
            <button id="addServerOpen" type="button" class="p-1.5 text-ash-grey-400 hover:text-vintage-grape-400 transition-colors" title="<%= t('servers.addNew') %>">
              <i class="fas fa-plus"></i>
            </button>
          </div>
          <div class="space-y-1">
            <button onclick="window.loadServers()" class="w-full flex items-center space-x-3 px-4 py-2 rounded-lg text-ash-grey-300 hover:bg-midnight-violet-800 transition">
              <i class="fas fa-sync-alt w-4 flex-shrink-0"></i>
              <span class="whitespace-nowrap"><%= t('servers.refreshData') %></span>
            </button>
          </div>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider mb-3"><%= t('servers.statusOverview') %></h3>
          <div class="grid grid-cols-2 gap-2">
            <div class="bg-midnight-violet-800 border border-midnight-violet-700 rounded-lg p-3 text-center shadow-inner">
              <span class="block text-2xl font-black text-green-400" id="stat-online">-</span>
              <span class="text-[10px] font-bold text-green-500 uppercase tracking-wide"><%= t('servers.filterOnline') %></span>
            </div>
            <div class="bg-midnight-violet-800 border border-midnight-violet-700 rounded-lg p-3 text-center shadow-inner">
              <span class="block text-2xl font-black text-red-400" id="stat-offline">-</span>
              <span class="text-[10px] font-bold text-red-500 uppercase tracking-wide"><%= t('servers.filterOffline') %></span>
            </div>
          </div>
          <div class="mt-3 text-center">
            <span class="text-[10px] text-ash-grey-400 font-medium"><%= t('servers.totalServers') %> <span id="stat-total" class="font-bold text-ash-grey-50">-</span></span>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-3">
              <h3 class="text-xs font-semibold text-ash-grey-400 uppercase tracking-wider"><%= t('servers.recentActions') %></h3>
              <button onclick="window.deleteAllCommandLogs()"
                      class="text-[11px] text-ash-grey-400 hover:text-red-500 transition-colors flex items-center gap-1"
                      title="<%= t('servers.deleteAll') %>">
                  <i class="fas fa-trash text-[10px]"></i> <%= t('servers.deleteAll') %>
              </button>
          </div>

          <div id="mini-log-filter" class="mb-3"></div>

          <div id="mini-log-container" class="space-y-4 px-1 max-h-[350px] overflow-y-auto custom-scrollbar pr-2">
              <div class="animate-pulse flex gap-3 items-start">
                  <div class="w-7 h-7 rounded-full bg-midnight-violet-800 shrink-0"></div>
                  <div class="space-y-2 w-full mt-1">
                      <div class="h-2.5 bg-midnight-violet-800 rounded w-full"></div>
                      <div class="h-2 bg-midnight-violet-800/50 rounded w-12"></div>
                  </div>
              </div>
          </div>
      </div>

      </div>
    </nav>

    <!-- Footer -->
    <div class="shrink-0 border-t border-midnight-violet-800 p-4">
      <div class="flex items-center space-x-3 px-1 py-1">
        <div class="w-8 h-8 bg-vintage-grape-600 rounded-full flex items-center justify-center flex-shrink-0">
          <span class="text-ash-grey-50 text-sm font-semibold"><%= currentUser ? currentUser[0].toUpperCase() : 'U' %></span>
        </div>
        <div class="flex-1 overflow-hidden">
          <p class="text-ash-grey-50 text-sm font-medium truncate"><%= currentUser || 'User' %></p>
          <p class="text-ash-grey-400 text-xs"><%= t('nav.signedIn') %></p>
        </div>
        <form method="POST" action="/logout">
          <button type="submit" title="<%= t('nav.signOut') %>" class="p-2 rounded-full hover:bg-midnight-violet-700 transition text-ash-grey-300 hover:text-red-400">
            <i class="fas fa-sign-out-alt"></i>
          </button>
        </form>
      </div>
      <!-- Language switcher -->
      <div class="flex items-center justify-center gap-2 mt-3 px-4">
        <a href="/lang/en" class="text-xs px-2 py-1 rounded <%= lng === 'en' ? 'bg-vintage-grape-600 text-white' : 'text-ash-grey-400 hover:text-vintage-grape-300' %>">EN</a>
        <span class="text-ash-grey-600 text-xs">|</span>
        <a href="/lang/cs" class="text-xs px-2 py-1 rounded <%= lng === 'cs' ? 'bg-vintage-grape-600 text-white' : 'text-ash-grey-400 hover:text-vintage-grape-300' %>">CS</a>
      </div>
    </div>

  </div>
</aside>
