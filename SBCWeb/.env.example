# Server Configuration
# UPRAV PODLE SVÉHO PROSTŘEDÍ!

# Port a host, na kterém server poběží
# Příklad: SERVER_PORT=8080
SERVER_PORT=

# Kterým hostům se server zpřístupní (0.0.0.0 = všem)
SERVER_HOST=

# ZMĚŇ NA VLASTNÍ TAJNÝ KLÍČ! (minimálně 32 znaků)
# Příklad: SESSION_SECRET=tvoje-super-tajne-heslo-12345678901234567890
SESSION_SECRET=

# Database path (relativní cesta od rootu)
DATABASE_PATH=

# MQTT Broker - IP adresa nebo hostname
# Příklad: MQTT_BROKER_IP=192.168.1.100 nebo mqtt.example.com
MQTT_BROKER_IP=

# MQTT Broker port (standardně 1883, TLS 8883)
MQTT_BROKER_PORT=

# Zpoždění před odesláním konfigurací po připojení (ms)
MQTT_PUSH_DELAY=

# Wake-on-LAN UDP port
WOL_UDP_PORT=

# Interval agregace měřených dat (ms)
MEASUREMENT_AGGREGATION_INTERVAL=
